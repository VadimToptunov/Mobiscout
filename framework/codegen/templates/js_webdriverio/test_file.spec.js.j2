const APP_PACKAGE = {{ model.app_package | js_str }};
// Condition-based wait budget (ms) — poll for the element instead of a fixed
// pause, so specs stay in sync with async UI without flaking at machine speed.
const TIMEOUT = 10000;

// Locate an element, waiting for it to appear and self-healing through ranked
// selectors — each poll tries every selector until one exists or we time out.
async function find(selectors) {
    let found = null;
    await driver.waitUntil(
        async () => {
            for (const selector of selectors) {
                const el = await driver.$(selector);
                if (await el.isExisting()) {
                    found = el;
                    return true;
                }
            }
            return false;
        },
        { timeout: TIMEOUT, interval: 300, timeoutMsg: `No selector matched: ${selectors.join(', ')}` }
    );
    return found;
}

{% for case in model.cases %}
describe({{ model.name | js_str }}, () => {
    it({{ case.name | js_str }}, async () => {
{% for step in case.steps %}
{% if step.description %}
        // {{ step.description }}
{% endif %}
{% if step.action.value == "launch" %}
        await driver.activateApp(APP_PACKAGE);
{% elif step.action.value == "tap" %}
        await (await find({{ step.selector | selector_array }})).click();
{% elif step.action.value == "type" %}
        await (await find({{ step.selector | selector_array }})).setValue({{ step.text | js_str }});
{% elif step.action.value == "back" %}
        await driver.back();
{% elif step.action.value == "long_press" %}
        await driver.execute('mobile: longClickGesture', { elementId: (await find({{ step.selector | selector_array }})).elementId, duration: 1000 });
{% elif step.action.value == "scroll_to" %}
        await $({{ ('android=new UiScrollable(new UiSelector().scrollable(true)).scrollIntoView(new UiSelector().textContains("' ~ (step.selector.description or step.selector.value) ~ '"))') | js_str }});
{% elif step.action.value == "deep_link" %}
{% if model.platform.value == "ios" %}
        await driver.url({{ step.text | js_str }});
{% else %}
        await driver.execute('mobile: deepLink', { url: {{ step.text | js_str }}, package: APP_PACKAGE });
{% endif %}
{% elif step.action.value == "press_key" %}
        await driver.pressKeyCode({{ step.text | keycode }});
{% elif step.action.value == "wait" %}
        // Condition-based: wait for the screen to render rather than a fixed pause.
        await driver.waitUntil(async () => (await driver.$$('//*')).length > 0, { timeout: {{ (step.timeout | int or 5) * 1000 }}, interval: 300 });
{% elif step.action.value == "assert" %}
{% if step.assertion.value == "visible" %}
        await expect(await find({{ step.selector | selector_array }})).toBeDisplayed();
{% elif step.assertion.value == "text_equals" %}
        await expect(await find({{ step.selector | selector_array }})).toHaveText({{ step.expected | js_str }});
{% elif step.assertion.value == "enabled" %}
        await expect(await find({{ step.selector | selector_array }})).toBeEnabled();
{% endif %}
{% endif %}
{% endfor %}
    });
});

{% endfor %}
